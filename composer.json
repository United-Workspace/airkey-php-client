{
    "name": "sleevesup/evva-airkey-api",
    "description": "PHP SDK for the EVVA AirKey Cloud API (Generated)",
    "keywords": [
        "airkey",
        "evva",
        "php",
        "sdk",
        "api"
    ],
    "homepage": "https://github.com/United-Workspace/airkey-php-client",
    "license": "proprietary",
    "authors": [
        {
            "name": "United Workspace GmbH",
            "email": "sf@sleevesup.de"
        },
        {
            "name": "EVVA AirKey Team",
            "homepage": "https://integration.api.airkey.evva.com/"
        }
    ],
    "require": {
        "php": ">=8.0",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^4.8",
        "squizlabs/php_codesniffer": "~2.6",
        "friendsofphp/php-cs-fixer": "~2.12"
    },
    "autoload": {
        "psr-4": {
            "Evva\\AirKey\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Evva\\AirKey\\": "test/"
        }
    }
}